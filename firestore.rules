rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isLoggedIn()  { return request.auth != null; }
    function isSelf(uid)   { return request.auth.uid == uid; }
    function userRole()    { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isApproved()  { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true; }
    function isAdmin()     { return isLoggedIn() && userRole() == 'admin'; }
    function isSeller()    { return isLoggedIn() && userRole() == 'seller' && isApproved(); }
    function isDelivery()  { return isLoggedIn() && userRole() == 'delivery' && isApproved(); }
    function isBuyer()     { return isLoggedIn() && userRole() == 'buyer'; }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any logged-in user can read their own doc; admin can read all
      allow read:  if isLoggedIn() && (isSelf(uid) || isAdmin());
      // User can create their own doc on registration
      allow create: if isSelf(uid);
      // User can update own profile (name, phone, address, profileImageUrl)
      // Admin can update any user (role, isApproved, isActive)
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Products ──────────────────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone can read products (buyers see approved ones, filtered client-side)
      allow read: if true;
      // Only approved sellers can create products
      allow create: if isSeller() &&
                       request.resource.data.sellerId == request.auth.uid &&
                       request.resource.data.status == 'pending';
      // Seller can update their own product (except status/isApproved — admin only)
      allow update: if isAdmin() ||
                       (isSeller() &&
                        resource.data.sellerId == request.auth.uid &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['status', 'isApproved']));
      // Seller can delete own product; admin can delete any
      allow delete: if isAdmin() ||
                       (isSeller() && resource.data.sellerId == request.auth.uid);
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Buyer reads their own orders; seller reads orders they fulfilled;
      // delivery agent reads assigned orders; admin reads all
      allow read: if isLoggedIn() && (
        isAdmin() ||
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        (resource.data.sellerIds is list && request.auth.uid in resource.data.sellerIds) ||
        resource.data.deliveryAgentId == request.auth.uid
      );
      // Buyers create orders via Firestore SDK (transaction handles stock decrement)
      allow create: if isBuyer() && request.resource.data.buyerId == request.auth.uid;
      // Status updates allowed by: admin, seller (confirm/pack), delivery (dispatch/deliver), buyer (cancel only)
      allow update: if isAdmin() ||
                       (isSeller() && resource.data.sellerId == request.auth.uid) ||
                       isDelivery() ||
                       (isBuyer() &&
                        resource.data.buyerId == request.auth.uid &&
                        request.resource.data.status == 'cancelled' &&
                        resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ── Carts ─────────────────────────────────────────────────────────────────
    match /carts/{uid} {
      allow read, write: if isLoggedIn() && isSelf(uid);
    }

    // ── Wishlists ─────────────────────────────────────────────────────────────
    match /wishlists/{uid}/items/{itemId} {
      allow read, write: if isLoggedIn() && isSelf(uid);
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isBuyer() && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin() ||
                               (isBuyer() && resource.data.buyerId == request.auth.uid);
    }

    // ── Delivery Agents ───────────────────────────────────────────────────────
    match /deliveryAgents/{agentId} {
      allow read:  if isLoggedIn() && (isAdmin() || isDelivery());
      allow write: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
